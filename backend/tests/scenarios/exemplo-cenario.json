{
  "name": "Fluxo de Login Automacao",
  "config": {
    "screenshotEnabled": true,
    "screenshotInterval": 500
  },
  "blocks": [
    {
      "id": "inicio",
      "type": "goto",
      "params": {
        "url": "https://practicetestautomation.com/practice-test-login/",
        "waitUntil": "domcontentloaded"
      }
    },
    {
      "id": "aguardar-carregamento",
      "type": "wait",
      "params": {
        "timeout": 1000
      }
    },
    {
      "id": "captura-inicial",
      "type": "screenshot",
      "params": {
        "name": "01-pagina-inicial"
      }
    },
    {
      "id": "preencher-usuario",
      "type": "type",
      "params": {
        "selector": "input#username",
        "text": "student",
        "timeout": 5000
      }
    },
    {
      "id": "aguardar-campo1",
      "type": "wait",
      "params": {
        "timeout": 500
      }
    },
    {
      "id": "preencher-senha",
      "type": "type",
      "params": {
        "selector": "input#password",
        "text": "Password123",
        "timeout": 5000
      }
    },
    {
      "id": "aguardar-preenchimento",
      "type": "wait",
      "params": {
        "timeout": 500
      }
    },
    {
      "id": "captura-formulario",
      "type": "screenshot",
      "params": {
        "name": "02-formulario-preenchido"
      }
    },
    {
      "id": "enviar-formulario",
      "type": "click",
      "params": {
        "selector": "button#submit",
        "timeout": 5000
      }
    },
    {
      "id": "aguardar-resposta",
      "type": "wait",
      "params": {
        "timeout": 2000
      }
    },
    {
      "id": "captura-final",
      "type": "screenshot",
      "params": {
        "name": "03-resultado-final"
      }
    }
  ]
}